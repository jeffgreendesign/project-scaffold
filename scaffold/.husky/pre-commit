#!/bin/sh
set -e

# Quality gates — must pass before commit
# For full test suite, rely on CI. Pre-commit runs fast checks only.

# Detect package manager
if [ -f pnpm-lock.yaml ]; then
  PM_RUN="pnpm"
elif [ -f yarn.lock ]; then
  PM_RUN="yarn"
else
  PM_RUN="npm run"
fi

# Version floor check (if configured)
if [ -f "config/version-floors.json" ] && [ -f "scripts/version-floor-check.sh" ]; then
  bash scripts/version-floor-check.sh
fi

bash scripts/security-check.sh --strict

$PM_RUN lint
$PM_RUN typecheck
